pipeline {

  agent {
    docker {
      image 'savithri06/jenkins-agent:latest'
      args '-u root:root -v /var/run/docker.sock:/var/run/docker.sock --entrypoint=""'
      reuseNode true
    }
  }

  options {
    timestamps()
    durabilityHint('PERFORMANCE_OPTIMIZED')
  }

  environment {
    APP_DIR    = "SpringBootApp"
    IMAGE_NAME = "savithri06/springboot_boot"
    GIT_REPO   = "CICD-End-To-End"
    GIT_OWNER  = "Savithri0608"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build and Test') {
      steps {
        dir("${APP_DIR}") {
          sh 'mvn clean package'
        }
      }
    }

    stage('Static Code Analysis') {
      steps {
        dir("${APP_DIR}") {
          withSonarQubeEnv('sonarqube') {
            sh 'mvn sonar:sonar'
          }
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        dir("${APP_DIR}") {
          script {
            docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-creds') {
              def image = docker.build("${IMAGE_NAME}:${BUILD_NUMBER}")
              image.push()
              image.push("latest")
            }
          }
        }
      }
    }
//check
   stage('Update Deployment YAML') {
  steps {
    dir("${WORKSPACE}") {  

      withCredentials([
        usernamePassword(
          credentialsId: 'github-creds',
          usernameVariable: 'GIT_USERNAME',
          passwordVariable: 'GIT_TOKEN'
        )
      ]) {
        sh '''
          #!/bin/bash
          set -e

          echo "Fix git detached HEAD"
          git checkout main

git config --global --add safe.directory ${WORKSPACE}

echo "Before:"
cat springboot-k8s-manifests/deployment.yaml

sed -i "s|${IMAGE_NAME}:.*|${IMAGE_NAME}:${BUILD_NUMBER}|g" springboot-k8s-manifests/deployment.yaml

echo "After:"
cat springboot-k8s-manifests/deployment.yaml

git config user.email "${GIT_USERNAME}@users.noreply.github.com"
git config user.name "${GIT_USERNAME}"

git add springboot-k8s-manifests/deployment.yaml
git commit -m "[skip ci] Update image to ${BUILD_NUMBER}" || echo "No changes"

git push https://${GIT_USERNAME}:${GIT_TOKEN}@github.com/${GIT_OWNER}/${GIT_REPO} main
        '''
      }

    }
  }
}
  }

  post {
    always {
      cleanWs()
      sh 'docker image prune -f'
    }
  }
}
