pipeline {
agent {
  docker {
    image 'savithri06/jenkins-agent:latest'
    args '-u root:root -v /var/run/docker.sock:/var/run/docker.sock'
    reuseNode true
  }
}

stages {
stage('Checkout') {
  steps {
    checkout scm
  }
}

stage('Check Files') {
  steps {
    sh 'pwd'
    sh 'ls -l'
    sh 'ls -l SpringBootApp'
  }
}

stage('Build and Test') {
  steps {
    dir('SpringBootApp') {
      sh 'mvn clean package'
    }
  }
}

stage('Static Code Analysis') {
  steps {
    dir('SpringBootApp') {
      withSonarQubeEnv('sonarqube') {
        sh 'mvn sonar:sonar'
      }
    }
  }
}

stage('Build and Push Docker Image') {
  agent any

  steps {
    dir('SpringBootApp') {
      script {
        docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-creds') {
          def image = docker.build("savithri06/springboot_boot:${BUILD_NUMBER}")
          image.push()
        }
      }
    }
  }
}


}
}
